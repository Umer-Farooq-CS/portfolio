# Submissions will be emailed to the address linked to your Formspree account.
# For GitHub Pages: set VITE_FORMSPREE_FORM_ID as a repository secret and add it to the deploy workflow.
VITE_FORMSPREE_FORM_ID=your_formspree_form_id
